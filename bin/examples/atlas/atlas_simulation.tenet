// SECTION 3: THE JEVONS PARADOX
// ─────────────────────────────────────────────────────────────────────────────

print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━";
print "SECTION 3: THE JEVONS PARADOX (Market Expansion)";
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━";
print "";

print "HISTORICAL PRECEDENT:";
print "┌─────────────────────────────────────────────────────────────────┐";
print "│ UBER vs. TAXIS                                                  │";
print "│ - Taxi market (2010): $10B                                      │";
print "│ - Rideshare market (2023): $100B                                │";
print "│ - Uber didn't take taxi market; it created NEW demand           │";
print "└─────────────────────────────────────────────────────────────────┘";
print "";
print "ATLAS PREDICTION:";
print "┌─────────────────────────────────────────────────────────────────┐";
print "│ CREATOR ECONOMY EXPANSION                                       │";
print "│ - Current 'Creator Economy' (ad revenue): $100B                 │";
print "│ - With Atlas (Micro-MNC infrastructure): $1T+                   │";
print "│                                                                  │";
print "│ WHY?                                                             │";
print "│ 1. Lower barrier → More creators                                │";
print "│ 2. Ownership → Longer careers                                   │";
print "│ 3. Infrastructure → New business models                         │";
print "│ 4. Portability → Creator pricing power                          │";
print "└─────────────────────────────────────────────────────────────────┘";
print "";

// The Jevons model
game JevonsMarketExpansion {
    players NewCreator, TradWorker
    strategies JoinCreatorEconomy, StayTraditional, AtlasExists, AtlasDoesntExist
    
    payoff NewCreator {
        (JoinCreatorEconomy, AtlasExists): 80       // Low friction entry
        (JoinCreatorEconomy, AtlasDoesntExist): 30  // High risk
        (StayTraditional, AtlasExists): 40          // Opportunity cost
        (StayTraditional, AtlasDoesntExist): 50     // Safe job
    }
    
    payoff TradWorker {
        (JoinCreatorEconomy, AtlasExists): 70       // They might join too
        (JoinCreatorEconomy, AtlasDoesntExist): 20  // Too risky
        (StayTraditional, AtlasExists): 45          // Watching from sidelines
        (StayTraditional, AtlasDoesntExist): 55     // Status quo
    }
}

solve JevonsMarketExpansion;

print "";
print "✅ ANALYSIS: Atlas shifts the equilibrium toward ENTRY.";
print "    When entry is safe, more people enter.";
print "    The 'Creator Economy' becomes the 'Sovereign Economy.'";
print "";

